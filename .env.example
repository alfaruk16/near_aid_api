# Copy to .env and adjust. Anything left unset falls back to a safe dev default.
SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*

# PostgreSQL + PostGIS (required — see README → "Geospatial" for one-time setup).
# Values below are the defaults applied when unset.
DB_NAME=nearaid
DB_USER=nearaid
DB_PASSWORD=nearaid
DB_HOST=127.0.0.1
DB_PORT=5432

# GeoDjango shared libraries. Defaults to Homebrew paths in settings.py; override
# here on other platforms (e.g. Linux: /usr/lib/x86_64-linux-gnu/libgdal.so).
# GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib

# Redis powers the Channels layer, cache, and Celery in production.
# REDIS_URL=redis://127.0.0.1:6379/0

# Demo OTP code surfaced by /auth/otp/request in DEBUG (the mockup hints "123456").
# Set to "" to force random codes.
OTP_DEBUG_CODE=123456

# CORS (comma separated). Empty + DEBUG allows all origins.
# CORS_ALLOWED_ORIGINS=http://localhost:5173
